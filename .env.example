NODE_ENV=development
PORT=3000

# CORS (comma-separated). In production this is mandatory and cannot be '*'
CORS_ALLOWED_ORIGINS=http://localhost:8080
FRONTEND_URL=http://localhost:8080

# Virtualbadge
VIRTUALBADGE_API_KEY=replace-with-virtualbadge-api-key
VIRTUALBADGE_API_BASE_URL=https://api.virtualbadge.io
VIRTUALBADGE_CREATE_RECIPIENT_ENDPOINT=/v2/public/recipient/?expand=certificate
VIRTUALBADGE_TEMPLATE_GLOBAL_TALENT=replace-with-template-id
VIRTUALBADGE_TEMPLATE_GLOBAL_LEADER=replace-with-template-id
VIRTUALBADGE_TEMPLATE_GLOBAL_CHAMPION=replace-with-template-id

# Database
DATABASE_URL=postgresql://user:password@host:5432/database
# Optional CA certificate for Postgres TLS (single line with escaped \n)
# Use when your Postgres provider requires a custom CA chain.
DB_SSL_CA=-----BEGIN CERTIFICATE-----\nMIID...\n-----END CERTIFICATE-----

# OpenAI
OPENAI_API_KEY=replace-with-openai-api-key

# Development only (do not use in production)
DB_SSL_INSECURE=false
